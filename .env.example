# =========================================================================
# Variáveis do monorepo GDS — copie este arquivo para .env e ajuste valores
# =========================================================================

# ---- Ambiente -----------------------------------------------------------
APP_ENV=dev

# ---- Portas do host (mude se já estiverem em uso) ------------------------
MYSQL_HOST_PORT=3310
BACK_HOST_PORT=9001
CODEGEN_HOST_PORT=9003
FRONT_HOST_PORT=9000

# ---- MySQL ---------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE_BACK=gds_back

# ---- Back (Symfony API) --------------------------------------------------
BACK_APP_SECRET=change-me-back-secret-d6ab621663ee840f6cd2dfe1c56f343e
BACK_DATABASE_URL=mysql://root:root@mysql:3306/gds_back?serverVersion=8.0
BACK_JWT_PASSPHRASE=change-me-jwt-passphrase
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

# URL do code-generator usada pelo back para disparar geração (refator E4/E5)
CODE_GENERATOR_URL=http://codegen-nginx

# ---- Code Generator ------------------------------------------------------
CODEGEN_APP_SECRET=change-me-codegen-secret-66d816892c4360f48c00d2c2a72a1ccf

# URL do back usada pelo code-gen para callbacks (getRepository / getServer)
BACK_URL=http://back-nginx

# Em ambiente local, MOCK_DEPLOY=1 desativa provisionamento EC2 e grava o
# código gerado em /var/www/output/generated-apps/<app>.
MOCK_DEPLOY=1

# Diretório (dentro do container codegen) onde os apps gerados são gravados.
OUTPUT_DIR=/var/www/output/generated-apps

# Diretório (dentro do container codegen) com o template Base montado read-only.
BASE_TEMPLATE_DIR=/var/www/base-template

# Diretório (dentro do container codegen) onde os .zip dos apps gerados são salvos.
# Mapeado no host em ./output/downloads e servido pelo nginx em /downloads/.
ZIPS_DIR=/var/www/output/downloads

# URL pública dos zips (servida pelo codegen-nginx no host).
PUBLIC_DOWNLOADS_BASE_URL=http://localhost:9003/downloads

# Credenciais AWS — mantenha "mock" em local. Em produção, preencha real.
AWS_KEY=mock
AWS_SECRET=mock

# ---- Front (Vue/Vite) ----------------------------------------------------
# O front roda no browser; precisa apontar para a porta exposta no host.
VITE_API_BASE_URL=http://localhost:9001
