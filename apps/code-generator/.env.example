# =========================================================================
# Defaults do app `code-generator` (Symfony). Este arquivo é commitado.
# O bootstrap copia para .env quando ele não existe.
# Em runtime, o docker-compose.yml ainda sobrescreve várias destas via
# `environment:` (APP_SECRET, BACK_URL, AWS_*, MOCK_DEPLOY, OUTPUT_DIR,
# BASE_TEMPLATE_DIR, ZIPS_DIR, PUBLIC_DOWNLOADS_BASE_URL), puxando do .env
# do monorepo.
# =========================================================================

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-codegen-secret-66d816892c4360f48c00d2c2a72a1ccf
###< symfony/framework-bundle ###

###> aws/aws-sdk ###
AWS_KEY=mock
AWS_SECRET=mock
###< aws/aws-sdk ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> gds/integration ###
# URL do back usada como callback (substitui SNS/SQS no monorepo local).
BACK_URL=http://back-nginx

# Se 1, faz mock do deploy: copia base do volume local, grava em /var/www/output
# e notifica back via HTTP em vez de provisionar EC2 + publicar no GitHub.
MOCK_DEPLOY=1

# Diretório onde o code-gen escreve os apps gerados (volume montado pelo compose).
OUTPUT_DIR=/var/www/output/generated-apps

# Diretório do template Base (volume read-only montado pelo compose).
BASE_TEMPLATE_DIR=/var/www/base-template
###< gds/integration ###
