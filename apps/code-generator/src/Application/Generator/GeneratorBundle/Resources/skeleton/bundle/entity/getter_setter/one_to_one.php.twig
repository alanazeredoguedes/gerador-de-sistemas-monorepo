    {
        return $this->{{ attribute.attributeName }};
    }

    public function set{{ attribute.attributeName[:1]|upper ~ attribute.attributeName[1:] }}(?{{ attribute.owningSide.className }} ${{ attribute.attributeName }}): void
    {
        $this->{{ attribute.attributeName }} = ${{ attribute.attributeName }};
    }
