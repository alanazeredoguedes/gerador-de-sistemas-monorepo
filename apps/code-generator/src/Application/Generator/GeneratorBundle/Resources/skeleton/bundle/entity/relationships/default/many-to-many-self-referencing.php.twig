#[Entity]
class Usuario
{
    /** Muitos usuários têm muitos usuários. */
    #[ManyToMany(targetEntity: Usuario::class, mappedBy: 'amigos')]
    private Collection $meusAmigos;

    /** Muitos usuários têm muitos usuários. */
    #[JoinTable(name: 'amigos')]
    #[JoinColumn(name: 'usuario_id', referencedColumnName: 'id')]
    #[InverseJoinColumn(name: 'amigos_id', referencedColumnName: 'id')]
    #[ManyToMany(targetEntity: 'Usuario', inversedBy: 'meusAmigos')]
    private Collection $amigos;

    public function __construct() {
        $this->meusAmigos = new ArrayCollection();
        $this->amigos = new ArrayCollection();
    }

}