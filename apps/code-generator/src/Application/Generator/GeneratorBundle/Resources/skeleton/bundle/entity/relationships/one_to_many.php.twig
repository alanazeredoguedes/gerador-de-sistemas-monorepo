{% if attribute.typeAssociation == "unidirectional" %}
{% if attribute.inverseSide.className == "SonataMediaMedia" or attribute.inverseSide.className == "SonataMediaGallery" %}
    #[ORM\ManyToOne(targetEntity: {{ attribute.inverseSide.className }}::class, cascade: ['persist'])]
    private mixed ${{ attribute.attributeName }};
{% else %}
{% if not attribute.nullable %}
    #[Assert\NotNull]
    #[Assert\NotBlank]
{% endif %}
    #[ORM\ManyToOne(targetEntity: {{ attribute.inverseSide.className }}::class)]
    #[ORM\JoinColumn(name: '{{ attribute.attributeName }}_id', referencedColumnName: '{{ attribute.inverseSide.primaryKey }}', onDelete: 'SET NULL')]
    private {{ attribute.inverseSide.className }}|null ${{ attribute.attributeName }} = null;
{% endif %}
{% elseif attribute.typeAssociation == "self-referencing" %}
    #[ORM\OneToMany(mappedBy: '{{ attribute.attributeName }}', targetEntity: {{ attribute.className }}::class)]
    private Collection $list{{ attribute.attributeName[:1]|upper ~ attribute.attributeName[1:] }};

{% if not attribute.nullable %}
    #[Assert\NotNull]
    #[Assert\NotBlank]
{% endif %}
    #[ORM\ManyToOne(targetEntity: {{ attribute.className }}::class, inversedBy: 'list{{ attribute.attributeName[:1]|upper ~ attribute.attributeName[1:] }}')]
    #[ORM\JoinColumn(name: '{{ attribute.attributeName }}', referencedColumnName: '{{ attribute.classPrimaryKey }}', onDelete: 'SET NULL')]
    private {{ attribute.className }}|null ${{ attribute.attributeName }} = null;
{% elseif attribute.typeAssociation == "bidirectional" %}
{% if attribute.typeForeingKey == "owningSide"  %}
{% if not attribute.nullable %}
    #[Assert\NotNull]
    #[Assert\NotBlank]
{% endif %}
    #[ORM\ManyToOne(targetEntity: {{ attribute.inverseSide.className }}::class, inversedBy: '{{ attribute.inverseSide.attributeName }}')]
    #[ORM\JoinColumn(name: '{{ attribute.attributeName }}_{{ attribute.inverseSide.primaryKey }}', referencedColumnName: '{{ attribute.inverseSide.primaryKey }}', onDelete: 'SET NULL')]
    private {{ attribute.inverseSide.className }}|null ${{ attribute.attributeName }} = null;
{% elseif attribute.typeForeingKey == "inverseSide" %}
    #[ORM\OneToMany(mappedBy: '{{ attribute.owningSide.attributeName }}', targetEntity: {{ attribute.owningSide.className }}::class)]
    private Collection ${{ attribute.attributeName }};
{% endif %}
{% endif %}
