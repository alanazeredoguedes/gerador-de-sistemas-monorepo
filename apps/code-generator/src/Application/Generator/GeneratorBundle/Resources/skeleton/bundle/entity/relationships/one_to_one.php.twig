{% if attribute.typeAssociation == "unidirectional" %}
    /** Um {{ attribute.className }} pertence a um(a) {{ attribute.attributeName }}. */
{% if not attribute.nullable %}
    #[Assert\NotNull]
    #[Assert\NotBlank]
{% endif %}
    #[ORM\OneToOne(targetEntity: {{ attribute.inverseSide.className }}::class)]
    #[ORM\JoinColumn(name: '{{ attribute.attributeName }}_{{ attribute.classPrimaryKey }}', referencedColumnName: '{{ attribute.classPrimaryKey }}', onDelete: 'SET NULL')]
    private {{ attribute.inverseSide.className }}|null ${{ attribute.attributeName }} = null;
{% elseif attribute.typeAssociation == "self-referencing" %}
    /** Um {{ attribute.className }} tem um(a) {{ attribute.attributeName }}. */
{% if not attribute.nullable %}
    #[Assert\NotNull]
    #[Assert\NotBlank]
{% endif %}
    #[ORM\OneToOne(targetEntity: {{ attribute.className }}::class)]
    #[ORM\JoinColumn(name: '{{ attribute.attributeName }}_{{ attribute.classPrimaryKey }}', referencedColumnName: '{{ attribute.classPrimaryKey }}', onDelete: 'SET NULL')]
    private {{ attribute.className }}|null ${{ attribute.attributeName }} = null;
{% elseif attribute.typeAssociation == "bidirectional" %}
{% if attribute.typeForeingKey == "owningSide"  %}
    /** Um {{ attribute.className }} pertence a um(a) {{ attribute.inverseSide.className }} */
{% if not attribute.nullable %}
    #[Assert\NotNull]
    #[Assert\NotBlank]
{% endif %}
    #[ORM\OneToOne(inversedBy: '{{ attribute.inverseSide.attributeName }}', targetEntity: {{ attribute.inverseSide.className }}::class)]
    #[ORM\JoinColumn(name: '{{ attribute.attributeName }}_{{ attribute.inverseSide.primaryKey }}', referencedColumnName: '{{ attribute.inverseSide.primaryKey }}', onDelete: 'SET NULL')]
    private {{ attribute.inverseSide.className }}|null ${{ attribute.attributeName }} = null;
{% elseif attribute.typeForeingKey == "inverseSide" %}
    /** Um {{ attribute.className }} possui um(a) {{ attribute.owningSide.className }} */
    #[ORM\OneToOne(mappedBy: '{{ attribute.owningSide.attributeName }}', targetEntity: {{ attribute.owningSide.className }}::class)]
    private {{ attribute.owningSide.className }}|null ${{ attribute.attributeName }} = null;
{% endif %}
{% endif %}
