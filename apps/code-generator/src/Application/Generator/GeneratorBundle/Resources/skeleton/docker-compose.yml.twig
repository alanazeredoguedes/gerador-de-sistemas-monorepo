# -----------------------------------------------------------------------------
# Portas do host expostas por este projeto. Mude no .env do projeto caso já
# tenha algo rodando nessas portas — em especial se a sua instalação do GDS
# (monorepo) estiver de pé na mesma máquina, ela ocupa 3310 / 9000 / 9001 / 9003.
# Defaults aqui foram escolhidos para não colidir com o monorepo.
# -----------------------------------------------------------------------------

services:

  # Imagem — Container Aplicação PHP
  app:
    build:
      context: ./docker/php/
      dockerfile: Dockerfile
    image: app-php81
    container_name: {{ projectName }}-app
    restart: unless-stopped
    working_dir: /var/www/
    volumes:
      - ./:/var/www
    networks:
      - network-project

  # Imagem — Container Nginx
  nginx:
    image: nginx:1.17-alpine
    container_name: {{ projectName }}-nginx
    restart: unless-stopped
    ports:
      - "${APP_HOST_PORT:-8080}:80"
    volumes:
      - ./:/var/www
      - ./docker/nginx:/etc/nginx/conf.d
    networks:
      - network-project

  # Imagem — Container Mysql Versão 8.0
  db:
    image: mysql:8.0
    container_name: {{ projectName }}-mysql
    command: --default-authentication-plugin=mysql_native_password
    restart: always
    ports:
      - "${MYSQL_HOST_PORT:-3320}:3306"
    environment:
      - MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD:-root}
    volumes:
      - ./docker/mysql/data:/var/lib/mysql
    networks:
      - network-project

# Network Project
networks:
  network-project:
    driver: bridge
