{{ '{% extends "@ApplicationProjectContent/base/base_web.html.twig" %}' }}

{{ '{% block title %}' }}
    list
{{ '{% endblock %}' }}

{{ '{% block stylesheets %}' }}
    {{ '{{ parent() }}' }}

{{ '{% endblock %}' }}

{{ '{% block javascripts %}' }}
    {{ '{{ parent() }}' }}

{{ '{% endblock %}' }}

{{ '{% block javascriptsFooter %}' }}
    {{ '{{ parent() }}' }}

{{ '{% endblock %}' }}


{{ '{% block body %}' }}
    <div class="container" style="margin-top: 5%">
        <div class="row">

{% for modulo in registerBundle %}
            <div class=col-4 style="margin-bottom: 10px;">
                <div class="card">
                    <div class="card-body text-center">
                        <h5 class="card-title">Módulo {{ modulo['className'] }}</h5>
                        <p class="card-text">...</p>
                        <a href="{{ '{{ path("web_' }}{{ modulo['className'][:1]|lower ~  modulo['className'][1:] }}{{ '_list") }}' }}" class="btn btn-primary">Ir para</a>
                    </div>
                </div>
            </div>

{% endfor %}

        </div>
    </div>
{{ '{% endblock %}' }}




